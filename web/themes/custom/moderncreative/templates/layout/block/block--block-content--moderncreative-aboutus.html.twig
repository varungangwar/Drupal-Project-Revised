<div class="about-content">

  {% if content.field_heading %}
    <h2 class="about-title">
      {{ content.field_heading }}
    </h2>
  {% endif %}

  {% if content.body %}
    <div class="about-text">
      {{ content.body }}
    </div>
  {% endif %}

  {% if content.field_description %}
    <div class="about-text">
      {{ content.field_description }}
    </div>
  {% endif %}

  {% if content.field_primary_button %}
    <div class="about-btn">
      {{ content.field_primary_button }}
    </div>
  {% endif %}

</div>